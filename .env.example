# ============================================================
# Budget-Pal Environment Configuration
# Copy this file to .env and fill in all required values.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=budgetpal
POSTGRES_USER=budgetpal
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_HOST=budget-pal-db
POSTGRES_PORT=5432

# Full async SQLAlchemy URL (auto-composed in docker-compose, but can override here)
DATABASE_URL=postgresql+asyncpg://budgetpal:CHANGE_ME_strong_password_here@budget-pal-db:5432/budgetpal

# ── JWT Authentication ────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_64_char_hex_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Service Ports ─────────────────────────────────────────────
# Backend FastAPI (internal :8000, external mapping)
BACKEND_PORT=8010

# Frontend nginx (internal :80, external mapping)
FRONTEND_PORT=8011

# ── OpenAI (optional — AI categorization fallback) ────────────
# Leave empty to disable OpenAI fallback and use only local models
OPENAI_API_KEY=

# ── Frontend Build Args ───────────────────────────────────────
# Used during Docker build of frontend image
VITE_API_BASE_URL=/api

# ── Domain & Deployment ──────────────────────────────────────
STRATO_DOMAIN=budgetpal.doebele12.de
ENVIRONMENT=production

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8011,https://budgetpal.doebele12.de

# ── Swiss Financial Constants ─────────────────────────────────
# Annual CPI inflation rate for CHF projections
SWISS_INFLATION_RATE=0.015

# AHV maximum monthly pension (CHF, updated each year by federal council)
AHV_MAX_PENSION_CHF=2520

# AHV minimum monthly pension
AHV_MIN_PENSION_CHF=1260

# AHV full contribution years required for maximum pension
AHV_FULL_CONTRIBUTION_YEARS=44

# BVG Umwandlungssatz (conversion rate) — federal minimum
AHV_CONVERSION_RATE_BVG=0.068

# BVG coordination deduction (Koordinationsabzug) in CHF
BVG_COORDINATION_DEDUCTION=25725

# BVG minimum insured salary threshold
BVG_MINIMUM_SALARY=22050

# Pillar 3a maximum annual contribution (employees with Pillar 2)
PILLAR_3A_MAX_CONTRIBUTION=7056

# Pillar 3a maximum for self-employed (without Pillar 2)
PILLAR_3A_MAX_SELF_EMPLOYED=35280

# ── Projection Defaults ───────────────────────────────────────
# Default equity return assumption (nominal)
DEFAULT_EQUITY_RETURN=0.07

# Default bond/conservative return assumption (nominal)
DEFAULT_BOND_RETURN=0.02

# Default return volatility (std dev for Monte Carlo)
DEFAULT_RETURN_VOLATILITY=0.12

# Number of Monte Carlo simulation runs
MONTE_CARLO_RUNS=10000

# Projection cache TTL in seconds (24 hours)
PROJECTION_CACHE_TTL=86400

# ── Upload Settings ───────────────────────────────────────────
UPLOADS_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=50
